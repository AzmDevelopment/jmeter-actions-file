          <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="BeanShell PreProcessor" enabled="true">
            <boolProp name="resetInterpreter">false</boolProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="script">// Generate 10-digit Saudi National ID starting with 1
long nationalId = 1000000000L + (long)(Math.random() * 900000000L);
vars.put(&quot;uniqueId&quot;, String.valueOf(nationalId));

// Generate a short unique username (e.g., user2345)
int suffix = (int)(Math.random() * 9000) + 1000;
String username = &quot;user&quot; + suffix;
vars.put(&quot;uniqueUserName&quot;, username);

// Email derived from username (e.g., user2345@yopmail.com)
String email = username + &quot;@yopmail.com&quot;;
vars.put(&quot;uniqueEmail&quot;, email);

// Mobile number: 10 digits, starts with 9875
String mobile = &quot;9875&quot; + (100000 + (int)(Math.random() * 900000));
vars.put(&quot;uniqueMobile&quot;, mobile);
</stringProp>
          </BeanShellPreProcessor>
