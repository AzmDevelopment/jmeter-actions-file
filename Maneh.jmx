        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Signup as Individual" enabled="true">
          <stringProp name="HTTPSampler.domain">manehapp.azm-dev.com</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/api/individualbeneficiary/register</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&#xd;
  &quot;id&quot;: ${uniqueId},&#xd;
  &quot;arFullName&quot;: &quot;عبد الرحمن محمد&quot;,&#xd;
  &quot;enFullName&quot;: &quot;Abdul Rahman Mohammed&quot;,&#xd;
  &quot;dobH&quot;: 987654321,&#xd;
  &quot;dobG&quot;: &quot;1990-05-15T00:00:00&quot;,&#xd;
  &quot;email&quot;: &quot;${uniqueEmail}&quot;,&#xd;
  &quot;mobile&quot;: &quot;${uniqueMobile}&quot;,&#xd;
  &quot;mobileNumber&quot;: &quot;${uniqueMobile}&quot;,&#xd;
  &quot;arFirst&quot;: &quot;عبد الرحمن&quot;,&#xd;
  &quot;arFather&quot;: &quot;محمد&quot;,&#xd;
  &quot;arGrand&quot;: &quot;علي&quot;,&#xd;
  &quot;arFamily&quot;: &quot;محمد&quot;,&#xd;
  &quot;enFirst&quot;: &quot;Abdul Rahman&quot;,&#xd;
  &quot;enFather&quot;: &quot;Mohammed&quot;,&#xd;
  &quot;enGrand&quot;: &quot;Ali&quot;,&#xd;
  &quot;enFamily&quot;: &quot;Mohammed&quot;,&#xd;
  &quot;arNationality&quot;: &quot;سعودي&quot;,&#xd;
  &quot;enNationality&quot;: &quot;Saudi Arabian&quot;,&#xd;
  &quot;nationality&quot;: 1,&#xd;
  &quot;gender&quot;: &quot;Male&quot;,&#xd;
  &quot;idExpiryDateG&quot;: &quot;2030-01-16T10:30:00&quot;,&#xd;
  &quot;idExpiryDateH&quot;: 123456789,&#xd;
  &quot;idIssueDateG&quot;: &quot;2022-01-16T10:30:00&quot;,&#xd;
  &quot;idIssueDateH&quot;: 987654321,&#xd;
  &quot;idVersion&quot;: 1,&#xd;
  &quot;language&quot;: &quot;Arabic&quot;,&#xd;
  &quot;countryCode&quot;: &quot;966&quot;,&#xd;
  &quot;userName&quot;: &quot;${uniqueUserName}&quot;&#xd;
}&#xd;
</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
