          <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="BeanShell PreProcessor" enabled="true">
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <boolProp name="resetInterpreter">false</boolProp>
            <stringProp name="script">// Generate a 9-digit CR number
String cr = String.valueOf(100000000 + (int)(Math.random() * 900000000));
vars.put(&quot;crNumber&quot;, cr);

// Generate a unique username based on timestamp
String username = &quot;user&quot; + System.currentTimeMillis();
vars.put(&quot;username&quot;, username);

// Generate an 11-digit ID number
long idNumber = 10000000000L + (long)(Math.random() * 90000000000L);
vars.put(&quot;idNumber&quot;, String.valueOf(idNumber));

// Create an email from the username
String email = username + &quot;@yopmail.com&quot;;
vars.put(&quot;email&quot;, email);
</stringProp>
          </BeanShellPreProcessor>
